<!DOCTYPE html>
<html lang="es">
  <head>
    <title>HipapaAPP</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= action_cable_meta_tag %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- Navbar -->
    <nav class="nav-hipapa fixed top-0 left-0 right-0 z-50 flex items-center px-4 gap-4">
      <%= link_to "HipapaAPP", root_path, class: "brand shrink-0" %>

      <!-- Mobile toggle -->
      <button class="navbar-toggler ml-auto lg:hidden"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#mainNav"
              aria-expanded="false">
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Nav links -->
      <div class="navbar-collapse flex-1 lg:flex lg:items-center" id="mainNav">
        <div class="flex flex-col lg:flex-row lg:items-center gap-1 py-2 lg:py-0">
          <%= link_to "Inicio",    root_path,          class: "nav-link-item" %>
          <%= link_to "Productos", products_path,      class: "nav-link-item" %>
          <% if current_user&.admin? || current_user&.supervisor? %>
            <%= link_to "Reportes",  reportes_path,      class: "nav-link-item" %>
            <%= link_to "Impresora", printer_config_path, class: "nav-link-item" %>
          <% end %>
          <% if current_user&.admin? %>
            <%= link_to "Usuarios", admin_users_path, class: "nav-link-item" %>
          <% end %>
        </div>

        <!-- User section -->
        <% if logged_in? %>
          <div class="flex items-center gap-3 ml-auto py-2 lg:py-0">
            <div class="hidden md:flex items-center gap-2">
              <span class="nav-role-badge role-<%= current_user.role %>"><%= current_user.role %></span>
              <span class="nav-user-name"><%= current_user.name %></span>
            </div>
            <%= form_tag logout_path, method: :delete, style: "margin:0", data: { turbo: false } do %>
              <button type="submit" class="btn-nav-logout">Cerrar sesión</button>
            <% end %>
          </div>
        <% end %>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice.present? || alert.present? %>
      <div id="flash-container" class="fixed top-16 right-4 z-40 w-80 space-y-2">
        <% if notice.present? %>
          <div class="alert-success shadow-md">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="flex-1"><%= notice %></span>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="alert-danger shadow-md">
            <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <span class="flex-1"><%= alert %></span>
          </div>
        <% end %>
      </div>
      <script>setTimeout(() => { const el = document.getElementById('flash-container'); if(el) el.style.opacity='0'; }, 4000);</script>
    <% end %>

    <!-- Main content -->
    <main class="px-4 py-4 lg:px-6">
      <%= yield %>
    </main>

    <!-- Bootstrap JS (for modals + navbar collapse) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  </body>
</html>
