<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= BusinessSetting.current.nombre rescue 'Hi Papa' %> — Pedidos</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#f59e0b">
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <link rel="manifest" href="/manifest.json">
    <% setting = BusinessSetting.current rescue nil %>
    <% if setting %>
    <style>
      :root {
        --pub-brand: <%= setting.color_primario %>;
        --pub-dark:  <%= setting.color_secundario %>;
        --pub-accent:<%= setting.color_acento %>;
      }
    </style>
    <% end %>
  </head>
  <body class="bg-gray-50 min-h-screen">

    <!-- Header público -->
    <header style="background: var(--pub-dark, #0f172a);" class="sticky top-0 z-50 shadow-md">
      <div class="max-w-2xl mx-auto px-4 h-14 flex items-center justify-between">
        <% if setting&.logo&.attached? %>
          <%= image_tag setting.logo, class: "h-9 w-9 rounded-full object-cover" %>
        <% else %>
          <span class="text-2xl">🍔</span>
        <% end %>
        <span class="font-bold text-white text-lg"><%= setting&.nombre || 'Hi Papa' %></span>
        <!-- Carrito badge -->
        <button id="cart-toggle" class="relative text-white p-2 rounded-lg hover:bg-white/10 transition">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-9H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span id="cart-count" class="absolute -top-1 -right-1 bg-yellow-400 text-black text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center">0</span>
        </button>
      </div>
    </header>

    <!-- Flash -->
    <% if notice.present? || alert.present? %>
      <div class="max-w-2xl mx-auto px-4 mt-3">
        <% if notice.present? %>
          <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg p-3 text-sm"><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg p-3 text-sm"><%= alert %></div>
        <% end %>
      </div>
    <% end %>

    <main class="max-w-2xl mx-auto px-4 py-4 pb-32">
      <%= yield %>
    </main>

    <!-- Carrito flotante (slide-up) -->
    <div id="cart-panel" class="fixed bottom-0 left-0 right-0 z-50 hidden">
      <div class="max-w-2xl mx-auto">
        <div class="bg-white rounded-t-2xl shadow-2xl border-t border-gray-200">
          <div class="p-4 border-b flex items-center justify-between">
            <h3 class="font-bold text-lg">Tu pedido</h3>
            <button id="cart-close" class="text-gray-400 hover:text-gray-600">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div id="cart-items" class="p-4 max-h-64 overflow-y-auto space-y-2">
            <p class="text-gray-400 text-sm text-center py-4">Tu carrito está vacío</p>
          </div>
          <div class="p-4 border-t">
            <div class="flex justify-between font-bold text-lg mb-3">
              <span>Total</span>
              <span id="cart-total">$0</span>
            </div>
            <button id="checkout-btn" class="w-full py-3 rounded-xl font-bold text-black text-base" style="background: var(--pub-brand, #f59e0b);">
              Hacer pedido
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Checkout modal -->
    <div id="checkout-modal" class="fixed inset-0 bg-black/50 z-60 hidden items-center justify-center">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
        <div class="p-5 border-b flex items-center justify-between">
          <h3 class="font-bold text-lg">Confirmar pedido</h3>
          <button id="checkout-close" class="text-gray-400 hover:text-gray-600">✕</button>
        </div>
        <div class="p-5 space-y-4">
          <%= form_tag public_order_path, method: :post, id: 'checkout-form', data: { turbo: false } do %>
            <%= hidden_field_tag :cart_items, '', id: 'cart-items-json' %>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre *</label>
              <%= text_field_tag :nombre, '', class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-yellow-400", placeholder: "Tu nombre", required: true %>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">WhatsApp</label>
              <%= text_field_tag :whatsapp, '', class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-yellow-400", placeholder: "573001234567" %>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Tipo de pedido</label>
              <div class="flex gap-2">
                <label class="flex-1 border rounded-lg p-2 text-center text-sm cursor-pointer has-[:checked]:border-yellow-400 has-[:checked]:bg-yellow-50">
                  <input type="radio" name="tipo_servicio" value="llevar" checked class="sr-only"> Para llevar
                </label>
                <label class="flex-1 border rounded-lg p-2 text-center text-sm cursor-pointer has-[:checked]:border-yellow-400 has-[:checked]:bg-yellow-50">
                  <input type="radio" name="tipo_servicio" value="domicilio" class="sr-only"> Domicilio
                </label>
              </div>
            </div>
            <div id="direccion-field" class="hidden">
              <label class="block text-sm font-semibold text-gray-700 mb-1">Dirección</label>
              <%= text_field_tag :direccion, '', class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-yellow-400", placeholder: "Tu dirección" %>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-1">Notas</label>
              <%= text_area_tag :notas, '', class: "w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-yellow-400", rows: 2, placeholder: "Sin cebolla, sin gluten..." %>
            </div>
            <button type="submit" class="w-full py-3 rounded-xl font-bold text-black" style="background: var(--pub-brand, #f59e0b);">
              Confirmar pedido
            </button>
          <% end %>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <%= javascript_importmap_tags %>
    <% if content_for?(:js) %><%= yield :js %><% end %>
  </body>
</html>
