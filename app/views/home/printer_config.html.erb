<div class="pt-20 pb-10 px-4 max-w-2xl mx-auto">

  <div class="flex items-center gap-3 mb-6">
    <%= link_to root_path, class: "text-slate-500 hover:text-slate-700" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-xl font-bold text-slate-800">Configuración de Impresora</h1>
  </div>

  <%# ── Estado de QZ Tray ── %>
  <div class="card mb-4">
    <div class="card-body">
      <h2 class="font-semibold text-slate-700 mb-3">Estado de QZ Tray</h2>

      <div id="qz-status" class="flex items-center gap-2 mb-3">
        <span class="inline-block w-3 h-3 rounded-full bg-slate-300" id="qz-dot"></span>
        <span class="text-sm text-slate-600" id="qz-status-text">Verificando conexión…</span>
      </div>

      <div id="qz-not-found" class="hidden rounded-lg bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800">
        <strong>QZ Tray no encontrado.</strong> Para imprimir desde la nube necesitas instalarlo en este PC:
        <ol class="mt-2 ml-4 list-decimal space-y-1">
          <li>Instala <strong>Java 11+</strong>: <a href="https://adoptium.net" target="_blank" class="underline">adoptium.net</a></li>
          <li>Instala <strong>QZ Tray</strong>: <a href="https://qz.io/download/" target="_blank" class="underline">qz.io/download</a></li>
          <li>Ejecuta QZ Tray (aparece en la bandeja del sistema)</li>
          <li>Recarga esta página</li>
        </ol>
      </div>
    </div>
  </div>

  <%# ── Selección de impresora ── %>
  <div class="card mb-4" id="printer-section" style="display:none">
    <div class="card-body">
      <h2 class="font-semibold text-slate-700 mb-3">Impresora activa</h2>

      <div class="mb-3">
        <label class="block text-sm font-medium text-slate-600 mb-1">Selecciona la impresora para comandas:</label>
        <div class="flex gap-2">
          <select id="printer-select" class="flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
            <option value="">— Cargando impresoras… —</option>
          </select>
          <button id="btn-refresh" type="button"
                  class="px-3 py-2 rounded-md border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm">
            ↺
          </button>
        </div>
        <p class="text-xs text-slate-400 mt-1">
          Impresora actual: <strong id="current-printer-label">—</strong>
        </p>
      </div>

      <div class="flex gap-2 flex-wrap">
        <button id="btn-save" type="button"
                class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
          Guardar impresora
        </button>
        <button id="btn-test" type="button"
                class="px-4 py-2 rounded-md border border-slate-300 text-slate-700 text-sm hover:bg-slate-50">
          Imprimir prueba
        </button>
      </div>

      <div id="save-msg" class="hidden mt-2 text-sm text-green-600 font-medium">✓ Guardado</div>
      <div id="test-msg" class="hidden mt-2 text-sm"></div>
    </div>
  </div>

  <%# ── Modo de impresión ── %>
  <div class="card mb-4">
    <div class="card-body">
      <h2 class="font-semibold text-slate-700 mb-3">Modo de impresión</h2>
      <div class="space-y-2 text-sm">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="print_mode" value="qztray" id="mode-qz" class="accent-indigo-600">
          <span><strong>QZ Tray</strong> — Impresión silenciosa desde la nube <span class="text-green-600 font-medium">(recomendado)</span></span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="print_mode" value="rails" id="mode-rails">
          <span><strong>Rails backend</strong> — Solo funciona con servidor local en Windows</span>
        </label>
      </div>
      <button id="btn-save-mode" type="button"
              class="mt-3 px-4 py-2 rounded-md bg-slate-700 text-white text-sm hover:bg-slate-800">
        Guardar modo
      </button>
      <div id="mode-msg" class="hidden mt-2 text-sm text-green-600 font-medium">✓ Modo guardado</div>
    </div>
  </div>

  <%# ── Ayuda ── %>
  <details class="card">
    <summary class="card-body cursor-pointer font-semibold text-slate-700 text-sm select-none">
      ¿Cómo funciona QZ Tray?
    </summary>
    <div class="px-4 pb-4 text-sm text-slate-600 space-y-2">
      <p>QZ Tray es un programa que se instala en el PC del negocio y actúa como puente entre el navegador y la impresora.</p>
      <p>El flujo es:</p>
      <ol class="ml-4 list-decimal space-y-1">
        <li>Se crea un pedido en Rails (en la nube)</li>
        <li>El navegador construye el ticket ESC/POS</li>
        <li>El navegador se conecta a QZ Tray via WebSocket local (<code>wss://localhost:8181</code>)</li>
        <li>QZ Tray envía los datos directamente a la impresora</li>
      </ol>
      <p class="text-amber-700">
        <strong>Primera vez:</strong> QZ Tray mostrará un popup "¿Permitir conexión desde hipapa.app?".
        Haz clic en <strong>"Permitir siempre"</strong> y no volverá a aparecer.
      </p>
    </div>
  </details>

</div>

<script type="module">
import { connect, getPrinters, getSavedPrinter, savePrinter, printRaw } from 'qztray_printer';

const dot         = document.getElementById('qz-dot');
const statusText  = document.getElementById('qz-status-text');
const notFound    = document.getElementById('qz-not-found');
const section     = document.getElementById('printer-section');
const sel         = document.getElementById('printer-select');
const currentLbl  = document.getElementById('current-printer-label');
const saveMsg     = document.getElementById('save-msg');
const testMsg     = document.getElementById('test-msg');
const modeMsg     = document.getElementById('mode-msg');

// ── Mostrar impresora guardada
const saved = getSavedPrinter();
currentLbl.textContent = saved || '(ninguna)';

// ── Inicializar modo de impresión
const currentMode = localStorage.getItem('hipapa_print_mode') || 'qztray';
document.getElementById(currentMode === 'rails' ? 'mode-rails' : 'mode-qz').checked = true;

// ── Intentar conectar a QZ Tray
(async () => {
  if (typeof qz === 'undefined') {
    dot.className = 'inline-block w-3 h-3 rounded-full bg-red-400';
    statusText.textContent = 'QZ Tray JS no cargado (error de red)';
    notFound.classList.remove('hidden');
    return;
  }

  try {
    await connect();
    dot.className = 'inline-block w-3 h-3 rounded-full bg-green-400';
    statusText.textContent = 'QZ Tray conectado ✓';
    section.style.display = 'block';
    await loadPrinters();
  } catch (err) {
    dot.className = 'inline-block w-3 h-3 rounded-full bg-red-400';
    statusText.textContent = 'QZ Tray no responde — ¿está ejecutándose?';
    notFound.classList.remove('hidden');
  }
})();

async function loadPrinters() {
  try {
    const printers = await getPrinters();
    sel.innerHTML = '';
    if (!printers || printers.length === 0) {
      sel.innerHTML = '<option value="">— Sin impresoras instaladas —</option>';
      return;
    }
    printers.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p;
      opt.textContent = p;
      if (p === (getSavedPrinter() || '')) opt.selected = true;
      sel.appendChild(opt);
    });
  } catch (e) {
    sel.innerHTML = '<option value="">— Error al cargar impresoras —</option>';
  }
}

document.getElementById('btn-refresh').addEventListener('click', loadPrinters);

document.getElementById('btn-save').addEventListener('click', () => {
  const name = sel.value;
  if (!name) return;
  savePrinter(name);
  currentLbl.textContent = name;
  saveMsg.classList.remove('hidden');
  setTimeout(() => saveMsg.classList.add('hidden'), 2000);
});

document.getElementById('btn-test').addEventListener('click', async () => {
  const name = sel.value || getSavedPrinter();
  if (!name) { testMsg.textContent = 'Selecciona una impresora primero.'; testMsg.className = 'mt-2 text-sm text-amber-600'; testMsg.classList.remove('hidden'); return; }

  testMsg.textContent = 'Enviando prueba…';
  testMsg.className = 'mt-2 text-sm text-slate-500';
  testMsg.classList.remove('hidden');

  const operaciones = [
    { nombre: 'Iniciar', argumentos: [] },
    { nombre: 'EstablecerAlineacion', argumentos: [1] },
    { nombre: 'EstablecerTamañoFuente', argumentos: [2, 2] },
    { nombre: 'EscribirTexto', argumentos: ['HipapaAPP\n'] },
    { nombre: 'EstablecerTamañoFuente', argumentos: [1, 1] },
    { nombre: 'EscribirTexto', argumentos: ['Impresora: ' + name + '\n'] },
    { nombre: 'EscribirTexto', argumentos: ['Prueba de impresion OK\n'] },
    { nombre: 'Feed', argumentos: [4] },
    { nombre: 'Corte', argumentos: [] }
  ];

  try {
    await printRaw(name, operaciones);
    testMsg.textContent = '✓ Ticket de prueba enviado correctamente';
    testMsg.className = 'mt-2 text-sm text-green-600 font-medium';
  } catch (err) {
    testMsg.textContent = '✗ Error: ' + (err.message || err);
    testMsg.className = 'mt-2 text-sm text-red-600';
  }
});

document.getElementById('btn-save-mode').addEventListener('click', () => {
  const mode = document.querySelector('input[name="print_mode"]:checked')?.value || 'qztray';
  localStorage.setItem('hipapa_print_mode', mode);
  modeMsg.classList.remove('hidden');
  setTimeout(() => modeMsg.classList.add('hidden'), 2000);
});
</script>
