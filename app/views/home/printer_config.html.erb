<div class="pt-20 pb-10 px-4 max-w-2xl mx-auto">

  <div class="flex items-center gap-3 mb-6">
    <%= link_to root_path, class: "text-slate-500 hover:text-slate-700" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <h1 class="text-xl font-bold text-slate-800">Configuración de Impresora</h1>
  </div>

  <%# ── Modo de impresión ── %>
  <div class="card mb-4">
    <div class="card-body">
      <h2 class="font-semibold text-slate-700 mb-3">Modo de impresión</h2>
      <div class="space-y-2 text-sm">
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="radio" name="print_mode" value="webserial" id="mode-webserial" class="mt-0.5 accent-indigo-600">
          <span>
            <strong>Web Serial</strong> — Sin instalación, directo al puerto USB
            <span class="text-green-600 font-medium">(recomendado)</span>
            <br>
            <span class="text-slate-400 text-xs">Solo Chrome / Edge. La impresora debe aparecer como puerto COM en Windows.</span>
          </span>
        </label>
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="radio" name="print_mode" value="qztray" id="mode-qz" class="mt-0.5 accent-indigo-600">
          <span>
            <strong>QZ Tray</strong> — Requiere instalar QZ Tray y Java en el PC
            <br>
            <span class="text-slate-400 text-xs">Compatible con más tipos de impresoras (USB Printing Class, red).</span>
          </span>
        </label>
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="radio" name="print_mode" value="rails" id="mode-rails" class="mt-0.5">
          <span><strong>Rails backend</strong> — Solo funciona con servidor local en Windows</span>
        </label>
      </div>
      <button id="btn-save-mode" type="button"
              class="mt-3 px-4 py-2 rounded-md bg-slate-700 text-white text-sm hover:bg-slate-800">
        Guardar modo
      </button>
      <div id="mode-msg" class="hidden mt-2 text-sm text-green-600 font-medium">✓ Modo guardado</div>
    </div>
  </div>

  <%# ── Configuración Web Serial ── %>
  <div class="card mb-4" id="webserial-section" style="display:none">
    <div class="card-body">
      <h2 class="font-semibold text-slate-700 mb-1">Puerto serial</h2>
      <p class="text-xs text-slate-500 mb-3">
        Conecta la impresora por USB, luego haz clic en "Seleccionar puerto". El navegador mostrará
        una lista de puertos COM disponibles — elige el que corresponde a tu impresora.
      </p>

      <div id="ws-no-support" class="hidden rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm text-amber-800 mb-3">
        Tu navegador no soporta Web Serial. Usa <strong>Chrome o Edge</strong> (versión 89+).
      </div>

      <div id="ws-port-info" class="hidden rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-800 mb-3">
        Puerto configurado: <strong id="ws-port-label">—</strong>
      </div>

      <div class="flex gap-2 flex-wrap mb-3">
        <button id="btn-select-port" type="button"
                class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
          Seleccionar puerto
        </button>
        <button id="btn-test-ws" type="button"
                class="px-4 py-2 rounded-md border border-slate-300 text-slate-700 text-sm hover:bg-slate-50">
          Imprimir prueba
        </button>
        <button id="btn-clear-port" type="button"
                class="px-4 py-2 rounded-md border border-red-200 text-red-600 text-sm hover:bg-red-50">
          Olvidar puerto
        </button>
      </div>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <div class="flex items-center gap-2">
          <label class="text-sm text-slate-600 whitespace-nowrap">Velocidad (baud rate):</label>
          <select id="ws-baud" class="rounded-md border border-slate-300 px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
            <option value="9600">9600</option>
            <option value="19200">19200</option>
            <option value="38400">38400</option>
            <option value="57600">57600</option>
            <option value="115200">115200</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <label class="text-sm text-slate-600 whitespace-nowrap">Control de flujo:</label>
          <select id="ws-flow" class="rounded-md border border-slate-300 px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
            <option value="none">Ninguno (más común)</option>
            <option value="hardware">Hardware RTS/CTS</option>
          </select>
        </div>
        <button id="btn-save-baud" type="button"
                class="px-3 py-1 rounded-md border border-slate-300 text-slate-600 text-sm hover:bg-slate-50">
          Guardar ajustes
        </button>
      </div>

      <div id="ws-msg" class="hidden mt-2 text-sm"></div>
    </div>
  </div>

  <%# ── Configuración QZ Tray ── %>
  <div class="card mb-4" id="qztray-section" style="display:none">
    <div class="card-body">
      <h2 class="font-semibold text-slate-700 mb-3">Estado de QZ Tray</h2>

      <div id="qz-status" class="flex items-center gap-2 mb-3">
        <span class="inline-block w-3 h-3 rounded-full bg-slate-300" id="qz-dot"></span>
        <span class="text-sm text-slate-600" id="qz-status-text">Verificando conexión…</span>
      </div>

      <div id="qz-not-found" class="hidden rounded-lg bg-amber-50 border border-amber-200 p-4 text-sm text-amber-800">
        <strong>QZ Tray no encontrado.</strong> Para imprimir desde la nube necesitas instalarlo en este PC:
        <ol class="mt-2 ml-4 list-decimal space-y-1">
          <li>Instala <strong>Java 11+</strong>: <a href="https://adoptium.net" target="_blank" class="underline">adoptium.net</a></li>
          <li>Instala <strong>QZ Tray</strong>: <a href="https://qz.io/download/" target="_blank" class="underline">qz.io/download</a></li>
          <li>Ejecuta QZ Tray (aparece en la bandeja del sistema)</li>
          <li>Recarga esta página</li>
        </ol>
      </div>

      <div class="card mt-3" id="qz-printer-section" style="display:none">
        <div class="card-body">
          <h3 class="font-semibold text-slate-700 mb-3">Impresora activa</h3>
          <div class="mb-3">
            <div class="flex gap-2">
              <select id="printer-select" class="flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
                <option value="">— Cargando impresoras… —</option>
              </select>
              <button id="btn-refresh" type="button"
                      class="px-3 py-2 rounded-md border border-slate-300 text-slate-600 hover:bg-slate-50 text-sm">
                ↺
              </button>
            </div>
            <p class="text-xs text-slate-400 mt-1">
              Impresora actual: <strong id="current-printer-label">—</strong>
            </p>
          </div>
          <div class="flex gap-2 flex-wrap">
            <button id="btn-save" type="button"
                    class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700">
              Guardar impresora
            </button>
            <button id="btn-test" type="button"
                    class="px-4 py-2 rounded-md border border-slate-300 text-slate-700 text-sm hover:bg-slate-50">
              Imprimir prueba
            </button>
          </div>
          <div id="save-msg" class="hidden mt-2 text-sm text-green-600 font-medium">✓ Guardado</div>
          <div id="test-msg" class="hidden mt-2 text-sm"></div>
        </div>
      </div>
    </div>
  </div>

</div>

<script type="module">
import { connect, getPrinters, getSavedPrinter, savePrinter, printRaw as qzPrintRaw } from 'qztray_printer';
import { isSupported, requestPort, getSavedPortInfo, saveBaudRate, saveFlowControl, clearSavedPort, printRaw as wsPrintRaw } from 'webserial_printer';

// ── Estado del modo
const currentMode = localStorage.getItem('hipapa_print_mode') || 'qztray';
const modeRadio = document.getElementById(
  currentMode === 'webserial' ? 'mode-webserial' :
  currentMode === 'rails'     ? 'mode-rails'    : 'mode-qz'
);
if (modeRadio) modeRadio.checked = true;

function applyMode(mode) {
  document.getElementById('webserial-section').style.display = mode === 'webserial' ? 'block' : 'none';
  document.getElementById('qztray-section').style.display    = mode === 'qztray'    ? 'block' : 'none';
}
applyMode(currentMode);

document.querySelectorAll('input[name="print_mode"]').forEach(r => {
  r.addEventListener('change', () => applyMode(r.value));
});

document.getElementById('btn-save-mode').addEventListener('click', () => {
  const mode = document.querySelector('input[name="print_mode"]:checked')?.value || 'qztray';
  localStorage.setItem('hipapa_print_mode', mode);
  const msg = document.getElementById('mode-msg');
  msg.classList.remove('hidden');
  setTimeout(() => msg.classList.add('hidden'), 2000);
});

// ── Web Serial
const wsMsg       = document.getElementById('ws-msg');
const wsPortInfo  = document.getElementById('ws-port-info');
const wsPortLabel = document.getElementById('ws-port-label');
const wsBaud      = document.getElementById('ws-baud');
const wsFlow      = document.getElementById('ws-flow');

function showWsMsg(text, color) {
  wsMsg.textContent = text;
  wsMsg.className = 'mt-2 text-sm ' + (color || 'text-slate-600');
  wsMsg.classList.remove('hidden');
  setTimeout(() => wsMsg.classList.add('hidden'), 3000);
}

function refreshWsPortDisplay() {
  const info = getSavedPortInfo();
  if (info) {
    const baud = info.baudRate || 9600;
    const flow = info.flowControl === 'hardware' ? 'RTS/CTS' : 'sin control';
    if (info.usbVendorId != null || info.usbProductId != null) {
      const vid = info.usbVendorId  != null ? '0x' + info.usbVendorId.toString(16).padStart(4,'0')  : '?';
      const pid = info.usbProductId != null ? '0x' + info.usbProductId.toString(16).padStart(4,'0') : '?';
      wsPortLabel.textContent = `VID ${vid} / PID ${pid}  —  ${baud} baud, ${flow}`;
    } else {
      wsPortLabel.textContent = `Puerto configurado  —  ${baud} baud, ${flow}`;
    }
    wsPortInfo.classList.remove('hidden');
  } else {
    wsPortInfo.classList.add('hidden');
  }
}

if (!isSupported()) {
  document.getElementById('ws-no-support').classList.remove('hidden');
  document.getElementById('btn-select-port').disabled = true;
  document.getElementById('btn-test-ws').disabled = true;
}

// Mostrar configuración actual
const savedInfo = getSavedPortInfo();
if (savedInfo?.baudRate) wsBaud.value = String(savedInfo.baudRate);
if (savedInfo?.flowControl) wsFlow.value = savedInfo.flowControl;

refreshWsPortDisplay();

document.getElementById('btn-select-port').addEventListener('click', async () => {
  try {
    const baud = parseInt(wsBaud.value) || 9600;
    await requestPort(baud);
    refreshWsPortDisplay();
    showWsMsg('✓ Puerto guardado correctamente', 'text-green-600 font-medium');
  } catch (err) {
    if (err.name !== 'NotFoundError') { // usuario canceló el diálogo — no mostrar error
      showWsMsg('Error: ' + (err.message || err), 'text-red-600');
    }
  }
});

document.getElementById('btn-save-baud').addEventListener('click', () => {
  const baud = parseInt(wsBaud.value) || 9600;
  const flow = wsFlow.value || 'none';
  saveBaudRate(baud);
  saveFlowControl(flow);
  refreshWsPortDisplay();
  showWsMsg('✓ Ajustes guardados', 'text-green-600 font-medium');
});

document.getElementById('btn-clear-port').addEventListener('click', () => {
  clearSavedPort();
  refreshWsPortDisplay();
  showWsMsg('Puerto olvidado', 'text-slate-500');
});

document.getElementById('btn-test-ws').addEventListener('click', async () => {
  const info = getSavedPortInfo();
  if (!info) { showWsMsg('Primero selecciona un puerto.', 'text-amber-600'); return; }

  showWsMsg('Enviando prueba…', 'text-slate-500');
  const operaciones = [
    { nombre: 'Iniciar', argumentos: [] },
    { nombre: 'EstablecerAlineacion', argumentos: [1] },
    { nombre: 'EstablecerTamañoFuente', argumentos: [2, 2] },
    { nombre: 'EscribirTexto', argumentos: ['HipapaAPP\n'] },
    { nombre: 'EstablecerTamañoFuente', argumentos: [1, 1] },
    { nombre: 'EscribirTexto', argumentos: ['Web Serial OK\n'] },
    { nombre: 'EscribirTexto', argumentos: ['Baud: ' + (info.baudRate || 9600) + '\n'] },
    { nombre: 'Feed', argumentos: [4] },
    { nombre: 'Corte', argumentos: [] }
  ];
  try {
    await wsPrintRaw(operaciones);
    showWsMsg('✓ Ticket de prueba enviado correctamente', 'text-green-600 font-medium');
  } catch (err) {
    showWsMsg('✗ Error: ' + (err.message || err), 'text-red-600');
  }
});

// ── QZ Tray
const dot        = document.getElementById('qz-dot');
const statusText = document.getElementById('qz-status-text');
const notFound   = document.getElementById('qz-not-found');
const qzPrSec    = document.getElementById('qz-printer-section');
const sel        = document.getElementById('printer-select');
const currentLbl = document.getElementById('current-printer-label');
const saveMsg    = document.getElementById('save-msg');
const testMsg    = document.getElementById('test-msg');

if (currentMode === 'qztray') {
  const saved = getSavedPrinter();
  currentLbl.textContent = saved || '(ninguna)';

  (async () => {
    if (typeof qz === 'undefined') {
      dot.className = 'inline-block w-3 h-3 rounded-full bg-red-400';
      statusText.textContent = 'QZ Tray JS no cargado (error de red)';
      notFound.classList.remove('hidden');
      return;
    }
    try {
      await connect();
      dot.className = 'inline-block w-3 h-3 rounded-full bg-green-400';
      statusText.textContent = 'QZ Tray conectado ✓';
      qzPrSec.style.display = 'block';
      await loadPrinters();
    } catch {
      dot.className = 'inline-block w-3 h-3 rounded-full bg-red-400';
      statusText.textContent = 'QZ Tray no responde — ¿está ejecutándose?';
      notFound.classList.remove('hidden');
    }
  })();
}

async function loadPrinters() {
  try {
    const printers = await getPrinters();
    sel.innerHTML = '';
    if (!printers || printers.length === 0) {
      sel.innerHTML = '<option value="">— Sin impresoras instaladas —</option>';
      return;
    }
    printers.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p; opt.textContent = p;
      if (p === (getSavedPrinter() || '')) opt.selected = true;
      sel.appendChild(opt);
    });
  } catch {
    sel.innerHTML = '<option value="">— Error al cargar impresoras —</option>';
  }
}

document.getElementById('btn-refresh')?.addEventListener('click', loadPrinters);

document.getElementById('btn-save')?.addEventListener('click', () => {
  const name = sel.value;
  if (!name) return;
  savePrinter(name);
  currentLbl.textContent = name;
  saveMsg.classList.remove('hidden');
  setTimeout(() => saveMsg.classList.add('hidden'), 2000);
});

document.getElementById('btn-test')?.addEventListener('click', async () => {
  const name = sel.value || getSavedPrinter();
  if (!name) {
    testMsg.textContent = 'Selecciona una impresora primero.';
    testMsg.className = 'mt-2 text-sm text-amber-600';
    testMsg.classList.remove('hidden');
    return;
  }
  testMsg.textContent = 'Enviando prueba…';
  testMsg.className = 'mt-2 text-sm text-slate-500';
  testMsg.classList.remove('hidden');
  const operaciones = [
    { nombre: 'Iniciar', argumentos: [] },
    { nombre: 'EstablecerAlineacion', argumentos: [1] },
    { nombre: 'EstablecerTamañoFuente', argumentos: [2, 2] },
    { nombre: 'EscribirTexto', argumentos: ['HipapaAPP\n'] },
    { nombre: 'EstablecerTamañoFuente', argumentos: [1, 1] },
    { nombre: 'EscribirTexto', argumentos: ['Impresora: ' + name + '\n'] },
    { nombre: 'EscribirTexto', argumentos: ['Prueba de impresion OK\n'] },
    { nombre: 'Feed', argumentos: [4] },
    { nombre: 'Corte', argumentos: [] }
  ];
  try {
    await qzPrintRaw(name, operaciones);
    testMsg.textContent = '✓ Ticket de prueba enviado correctamente';
    testMsg.className = 'mt-2 text-sm text-green-600 font-medium';
  } catch (err) {
    testMsg.textContent = '✗ Error: ' + (err.message || err);
    testMsg.className = 'mt-2 text-sm text-red-600';
  }
});
</script>
