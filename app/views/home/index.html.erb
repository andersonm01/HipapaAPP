<div class="page-header">
  <h1 class="page-title">Mostrador</h1>
  <%= link_to root_path, class: "btn-primary" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    Nuevo Pedido
  <% end %>
</div>

<div class="flex flex-col lg:flex-row gap-4 w-full">

  <!-- ========================================
       PANEL DERECHO: Formulario / Detalle
       ======================================== -->
  <div class="lg:order-last flex-1">

    <% if @new_order_id.present? && @current_order.present? %>
      <!-- ---- Detalle del pedido actual ---- -->
      <div class="card flex flex-col" style="max-height: calc(100vh - 90px); overflow: hidden;">

        <!-- Header -->
        <div class="px-4 py-3 bg-navy-900 text-white rounded-t-xl flex items-center justify-between shrink-0">
          <div>
            <span class="text-xs text-slate-400">Pedido</span>
            <h2 class="font-bold text-lg leading-tight">#<%= @current_order.id %></h2>
          </div>
          <div class="flex items-center gap-1">
            <a href="#" class="btn-ghost btn-icon-sm text-white hover:bg-white/10"
               data-bs-toggle="modal" data-bs-target="#orderDetailModal" title="Ver detalle">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </a>
          </div>
        </div>

        <div class="overflow-y-auto flex-1 px-4 py-3 space-y-4">
          <!-- Hora inicio -->
          <div class="flex items-center gap-2 text-xs text-slate-500">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <%= @current_order.created_at.strftime("%d/%m/%y %H:%M:%S") %>
          </div>

          <!-- Tipo de servicio -->
          <div>
            <p class="form-label mb-2">Servicio</p>
            <% if @current_order.status == 0 %>
              <%= form_with url: update_servicio_order_path(@current_order), method: :patch, local: true, data: { turbo: false }, id: "tipoServicioForm" do |f| %>
                <div class="radio-group">
                  <label>
                    <input type="radio" name="tipo_servicio" value="mesa" <%= 'checked' if @current_order.tipo_servicio == 'mesa' %>>
                    <span>En mesa</span>
                  </label>
                  <label>
                    <input type="radio" name="tipo_servicio" value="llevar" <%= 'checked' if @current_order.tipo_servicio == 'llevar' %>>
                    <span>Llevar</span>
                  </label>
                  <label>
                    <input type="radio" name="tipo_servicio" value="domicilio" <%= 'checked' if @current_order.tipo_servicio == 'domicilio' %>>
                    <span>Domicilio</span>
                  </label>
                </div>
              <% end %>
            <% else %>
              <span class="badge-gray">
                <%= case @current_order.tipo_servicio
                    when 'llevar' then 'Para llevar'
                    when 'domicilio' then 'Domicilio'
                    else 'En mesa' end %>
              </span>
            <% end %>
          </div>

          <!-- Estado del pedido -->
          <% if @current_order.closed? %>
            <div class="alert-warning text-xs">
              <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              Pedido cerrado — sin modificaciones
            </div>
          <% elsif @current_order.cancelled? %>
            <div class="alert-warning text-xs" style="background:#fef2f2;border-color:#fecaca;color:#b91c1c;">
              <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
              Pedido cancelado<%= @current_order.cancel_reason.present? ? " — #{@current_order.cancel_reason}" : "" %>
            </div>
          <% end %>

          <!-- Productos confirmados -->
          <% if @order_items.present? && @order_items.any? %>
            <div>
              <p class="section-label mb-2">Confirmados</p>
              <div class="space-y-1.5 max-h-40 overflow-y-auto pr-1">
                <% @order_items.each do |item| %>
                  <div class="flex items-start justify-between gap-2 bg-slate-50 rounded-lg px-3 py-2">
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-slate-800 truncate"><%= item.product.nombre %></p>
                      <p class="text-xs text-slate-500"><%= item.cantidad %> × $<%= sprintf("%.2f", item.precio_unitario) %></p>
                      <% if item.comentario.present? %>
                        <p class="text-xs text-amber-600 italic mt-0.5"><%= item.comentario %></p>
                      <% end %>
                    </div>
                    <div class="flex items-center gap-1 shrink-0">
                      <span class="text-sm font-bold text-slate-700">$<%= sprintf("%.2f", item.subtotal) %></span>
                      <% if @current_order.open? %>
                        <%= form_with url: destroy_item_order_path(@current_order, item_id: item.id), method: :delete, local: true, data: { turbo: false }, class: "inline" do %>
                          <button type="submit" class="btn-icon-sm text-slate-400 hover:text-red-500"
                                  title="Eliminar producto"
                                  onclick="return confirm('¿Eliminar <%= j(item.product.nombre) %> del pedido?')">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                            </svg>
                          </button>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <!-- Selección temporal -->
          <div id="selectedProductsContainer" style="display:none;">
            <p class="section-label" style="margin-bottom:0.5rem;">Seleccionados</p>
            <div id="selectedProductsList" style="max-height:200px;overflow-y:auto;"></div>
          </div>

          <!-- Búsqueda + grid de productos -->
          <% if @current_order.open? %>
            <div>
              <input type="text" id="productSearch" class="form-input" placeholder="Buscar producto...">
            </div>

            <div id="productsGrid" class="grid grid-cols-3 gap-1.5 max-h-52 overflow-y-auto pr-1">
              <% if @products.present? %>
                <% @products.each do |product| %>
                  <div class="product-item" data-product-id="<%= product.id %>" data-product-name="<%= product.nombre.downcase %>" data-product-precio="<%= product.precio %>" data-product-category="<%= product.categoria.to_s.downcase %>">
                    <button type="button" class="product-btn add-product-btn w-full text-left text-xs"
                            data-product-id="<%= product.id %>"
                            data-product-name="<%= product.nombre %>"
                            data-product-precio="<%= product.precio %>">
                      <%= truncate(product.nombre, length: 22) %>
                    </button>
                  </div>
                <% end %>
              <% else %>
                <div class="col-span-2 text-center text-slate-400 text-sm py-4">Sin productos disponibles</div>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Footer: total + acciones -->
        <div class="shrink-0 rounded-b-xl overflow-hidden">
          <div class="px-4 py-3 bg-navy-900 text-white space-y-1">
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Total confirmado</span>
              <span class="font-bold">$<%= sprintf("%.2f", @current_order.total) %></span>
            </div>
            <div style="display:none;justify-content:space-between;font-size:0.875rem;" id="selectedTotalContainer">
              <span class="text-slate-400">Seleccionados</span>
              <span class="font-bold" id="selectedTotal">$0.00</span>
            </div>
          </div>

          <div class="p-3 bg-slate-50 border-t border-slate-200 space-y-2">
            <% if @current_order.open? %>
              <div class="flex justify-center gap-2">
                <%= form_with url: confirm_items_order_path(@current_order), method: :post, local: true, data: { turbo: false }, id: "confirmProductsForm" do |f| %>
                  <button type="submit" id="confirmProductsBtn" class="btn-primary col-6" disabled>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Confirmar Productos
                  </button>
                <% end %>
                <button type="button" class="btn-dark col-6" data-bs-toggle="modal" data-bs-target="#closeOrderModal">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                  </svg>
                  Cerrar Pedido
                </button>
              </div>
              <div class="flex justify-center">
                <button type="button" class="btn-outline-danger btn-xs w-full" data-bs-toggle="modal" data-bs-target="#cancelOrderModal">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                  Cancelar Pedido
                </button>
              </div>
            <% elsif @current_order.closed? %>
              <div class="alert-info text-xs">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                </svg>
                Pedido cerrado — sin modificaciones
              </div>
            <% elsif @current_order.cancelled? %>
              <div class="text-xs" style="display:flex;align-items:center;gap:0.5rem;padding:0.5rem 0.75rem;background:#fef2f2;border:1px solid #fecaca;border-radius:0.5rem;color:#b91c1c;">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
                Pedido cancelado
              </div>
            <% end %>
          </div>
        </div>
      </div>

    <% else %>
      <!-- ---- Formulario Nuevo Pedido ---- -->
      <div class="card">
        <div class="px-4 py-3 bg-navy-900 text-white rounded-t-xl shrink-0">
          <h2 class="font-bold">Nuevo Pedido</h2>
        </div>
        <div class="card-body">
          <%= form_tag orders_path, method: :post, data: { turbo: false } do %>
            <div class="space-y-4">
              <div>
                <label for="cliente" class="form-label">Cliente</label>
                <%= text_field_tag :cliente, nil, class: "form-input", placeholder: "Nombre del cliente", required: true %>
              </div>

              <div>
                <label class="form-label mb-2">Servicio</label>
                <div class="radio-group">
                  <label>
                    <input type="radio" name="tipo_servicio" value="mesa" checked>
                    <span>En mesa</span>
                  </label>
                  <label>
                    <input type="radio" name="tipo_servicio" value="llevar">
                    <span>Llevar</span>
                  </label>
                  <label>
                    <input type="radio" name="tipo_servicio" value="domicilio">
                    <span>Domicilio</span>
                  </label>
                </div>
              </div>

              <div>
                <label for="mesero" class="form-label">Mesero</label>
                <%= select_tag :mesero,
                    options_for_select([
                      ["Seleccionar mesero...", ""],
                      ["Mesero 1", "mesero1"],
                      ["Mesero 2", "mesero2"],
                      ["Mesero 3", "mesero3"]
                    ]),
                    class: "form-select" %>
              </div>

              <div>
                <label for="comentario" class="form-label">Comentario <span class="text-slate-400 font-normal">(opcional)</span></label>
                <%= text_area_tag :comentario, nil, class: "form-textarea", rows: 3, placeholder: "Instrucciones especiales..." %>
              </div>

              <button type="submit" class="btn-primary w-full">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Crear Pedido
              </button>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- ========================================
       PANEL IZQUIERDO: Tablas de pedidos
       ======================================== -->
  <div class="flex-1">

    <!-- Tabla EN CURSO -->
    <div class="card">
      <div class="card-header">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
          <h2 class="font-semibold text-slate-800">En Curso</h2>
          <span class="badge-success"><%= @orders.count %></span>
        </div>
      </div>
      <% if @orders.present? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>#</th>
                <th>Hora</th>
                <th>Cliente</th>
                <th>Servicio</th>
                <th>Estado cocina</th>
                <th>Total</th>
                <th class="text-center w-14">Cerrar</th>
              </tr>
            </thead>
            <tbody>
              <% @orders.each do |order| %>
                <tr class="order-row clickable" data-order-id="<%= order.id %>">
                  <td class="font-mono text-xs text-slate-400"><%= order.id %></td>
                  <td class="text-xs text-slate-500"><%= order.created_at.strftime("%H:%M") %></td>
                  <td class="font-semibold text-slate-800"><%= order.cliente %></td>
                  <td>
                    <span class="badge-gray text-xs">
                      <%= case order.tipo_servicio
                          when 'llevar' then 'Llevar'
                          when 'domicilio' then 'Domicilio'
                          else 'Mesa' end %>
                    </span>
                  </td>
                  <td class="font-semibold text-slate-800"><%= order.kitchen_status %></td>
                  <td class="font-bold text-slate-800">$<%= sprintf("%.2f", order.total) %></td>
                  <td class="text-center" onclick="event.stopPropagation()">
                    <%= form_with url: close_order_order_path(order), method: :post, local: true, data: { turbo: false }, class: "inline" do |f| %>
                      <%= f.hidden_field :monto_pagado, value: order.total %>
                      <%= f.hidden_field :tipo_pago, value: "efectivo" %>
                      <%= f.hidden_field :vuelto, value: 0 %>
                      <button type="submit" class="btn-outline-danger btn-xs"
                              title="Cerrar pedido #<%= order.id %>"
                              onclick="return confirm('¿Cerrar pedido #<%= order.id %>?')">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                      </button>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state py-8">
          <svg class="w-10 h-10 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <p class="text-sm">Sin pedidos en curso</p>
        </div>
      <% end %>
    </div>

    <!-- Tabla CERRADAS -->
    <div class="card">
      <div class="card-header">
        <div class="flex items-center gap-2">
          <h2 class="font-semibold text-slate-800">Últimas Cerradas</h2>
          <span class="badge-gray"><%= @closed_orders.count %></span>
        </div>
      </div>
      <% if @closed_orders.present? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>#</th>
                <th>Hora</th>
                <th>Cliente</th>
                <th>Pago</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% @closed_orders.each do |order| %>
                <tr>
                  <td class="font-mono text-xs text-slate-400"><%= order.id %></td>
                  <td class="text-xs text-slate-500"><%= order.created_at.strftime("%d/%m %H:%M") %></td>
                  <td class="text-slate-700"><%= order.cliente %></td>
                  <td>
                    <% if order.tipo_pago == 'efectivo' %>
                      <span class="badge-success">Efectivo</span>
                    <% elsif order.tipo_pago.present? %>
                      <span class="badge-info">Transferencia</span>
                    <% end %>
                  </td>
                  <td class="font-bold text-slate-800">$<%= sprintf("%.2f", order.total) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state py-8">
          <p class="text-sm">No hay pedidos cerrados recientes</p>
        </div>
      <% end %>
    </div>

    <!-- Tabla CANCELADAS -->
    <% if @cancelled_orders.present? %>
    <div class="card mt-4">
      <div class="card-header">
        <div class="flex items-center gap-2">
          <h2 class="font-semibold text-slate-800">Cancelados Recientes</h2>
          <span class="badge-gray"><%= @cancelled_orders.count %></span>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th>#</th>
              <th>Hora</th>
              <th>Cliente</th>
              <th>Motivo</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            <% @cancelled_orders.each do |order| %>
              <tr style="opacity:0.65;">
                <td class="font-mono text-xs text-slate-400"><%= order.id %></td>
                <td class="text-xs text-slate-500"><%= order.cancelled_at&.strftime("%d/%m %H:%M") || order.created_at.strftime("%d/%m %H:%M") %></td>
                <td class="text-slate-700"><%= order.cliente %></td>
                <td class="text-xs text-slate-500 italic"><%= order.cancel_reason.presence || "—" %></td>
                <td class="font-bold text-slate-400">$<%= sprintf("%.2f", order.total) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <% end %>
  </div>
</div>

<!-- =============================================
     MODAL: Cerrar Pedido
     ============================================= -->
<% if @current_order.present? && @current_order.open? %>
<div class="modal fade" id="closeOrderModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-brand">
        <h5 class="modal-title">Cerrar Pedido #<%= @current_order.id %></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>

      <%= form_with url: close_order_order_path(@current_order), method: :post, local: true, data: { turbo: false }, id: "closeOrderForm" do |f| %>
        <div class="modal-body space-y-4">
          <!-- Total -->
          <div class="flex items-center justify-between bg-navy-900 text-white rounded-xl px-5 py-4">
            <span class="text-slate-400 text-sm">Total a pagar</span>
            <span class="text-2xl font-bold" id="orderTotal">$<%= sprintf("%.2f", @current_order.total) %></span>
          </div>

          <!-- Tipo de pago -->
          <div>
            <p class="form-label mb-2">Tipo de pago</p>
            <div class="radio-group">
              <label>
                <input type="radio" name="tipo_pago" id="tipo_efectivo" value="efectivo" checked>
                <span>💵 Efectivo</span>
              </label>
              <label>
                <input type="radio" name="tipo_pago" id="tipo_transferencia" value="transferencia">
                <span>🏦 Transferencia</span>
              </label>
            </div>
          </div>

          <!-- Monto recibido -->
          <div>
            <label for="monto_pagado" class="form-label">Monto recibido</label>
            <div class="input-group">
              <span class="input-group-text font-bold">$</span>
              <input type="number" class="form-input rounded-none" id="monto_pagado" name="monto_pagado"
                     step="0.01" min="0" required value="<%= sprintf("%.2f", @current_order.total) %>">
            </div>
            <p class="form-hint">Monto entregado por el cliente</p>
          </div>

          <!-- Vuelto -->
          <div id="vueltoContainer" style="display:none;">
            <div id="vueltoCard" style="display:flex;align-items:center;justify-content:space-between;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0.75rem;padding:0.75rem 1rem;">
              <span style="font-size:0.875rem;font-weight:600;color:#15803d;" id="vueltoLabel">Vuelto a devolver:</span>
              <span style="font-size:1.25rem;font-weight:700;color:#15803d;" id="vueltoAmount">$0.00</span>
            </div>
          </div>

          <input type="hidden" id="vuelto" name="vuelto" value="0">
        </div>

        <div class="modal-footer">
          <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Confirmar Cierre
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

<!-- =============================================
     MODAL: Cancelar Pedido
     ============================================= -->
<% if @current_order.present? && @current_order.open? %>
<div class="modal fade" id="cancelOrderModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="background:#dc2626;">
        <h5 class="modal-title text-white">Cancelar Pedido #<%= @current_order.id %></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <%= form_with url: cancel_order_order_path(@current_order), method: :post, local: true, data: { turbo: false } do |f| %>
        <div class="modal-body space-y-4">
          <div class="text-sm text-slate-600">
            Esta acción cancelará el pedido de <strong><%= @current_order.cliente %></strong>
            con un total de <strong>$<%= sprintf("%.2f", @current_order.total) %></strong>.
            Esta acción no se puede deshacer.
          </div>
          <div>
            <label for="cancel_reason" class="form-label">Motivo de cancelación <span class="text-slate-400 font-normal">(opcional)</span></label>
            <%= text_area_tag :cancel_reason, nil, class: "form-textarea", rows: 2, placeholder: "Ej: Cliente desistió, error en el pedido..." %>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-secondary" data-bs-dismiss="modal">Volver</button>
          <button type="submit" class="btn-danger" style="background:#dc2626;color:white;border:none;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;">
            Sí, cancelar pedido
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>

<!-- =============================================
     MODAL: Detalle del Pedido
     ============================================= -->
<% if @current_order.present? %>
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-brand">
        <h5 class="modal-title">Pedido #<%= @current_order.id %></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body space-y-4">
        <!-- Info general -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 bg-slate-50 rounded-xl p-4">
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Cliente</p>
            <p class="font-semibold text-slate-800"><%= @current_order.cliente || '—' %></p>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Mesero</p>
            <p class="font-semibold text-slate-800"><%= @current_order.mesero || '—' %></p>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Servicio</p>
            <p class="font-semibold text-slate-800">
              <%= case @current_order.tipo_servicio
                  when 'llevar' then 'Para llevar'
                  when 'domicilio' then 'Domicilio'
                  else 'En mesa' end %>
            </p>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">Estado</p>
            <% if @current_order.status == 0 %>
              <span class="badge-success">En curso</span>
            <% else %>
              <span class="badge-danger">Cerrado</span>
            <% end %>
          </div>
          <div class="col-span-2 md:col-span-2">
            <p class="text-xs text-slate-500 mb-0.5">Fecha</p>
            <p class="font-semibold text-slate-800"><%= @current_order.created_at.strftime("%d/%m/%Y %H:%M:%S") %></p>
          </div>
          <% if @current_order.comentario.present? %>
            <div class="col-span-2 md:col-span-3">
              <p class="text-xs text-slate-500 mb-0.5">Comentario</p>
              <p class="text-slate-700 text-sm italic"><%= @current_order.comentario %></p>
            </div>
          <% end %>
        </div>

        <!-- Productos -->
        <% if @order_items.present? && @order_items.any? %>
          <div class="overflow-x-auto rounded-xl border border-slate-200">
            <table class="table">
              <thead>
                <tr>
                  <th>Producto</th>
                  <th class="text-center">Cant.</th>
                  <th class="text-right">Precio Unit.</th>
                  <th class="text-right">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                <% @order_items.each do |item| %>
                  <tr>
                    <td>
                      <p class="font-semibold text-slate-800"><%= item.product.nombre %></p>
                      <% if item.comentario.present? %>
                        <p class="text-xs text-amber-600 italic"><%= item.comentario %></p>
                      <% end %>
                    </td>
                    <td class="text-center font-mono"><%= item.cantidad %></td>
                    <td class="text-right text-slate-600">$<%= sprintf("%.2f", item.precio_unitario) %></td>
                    <td class="text-right font-bold text-slate-800">$<%= sprintf("%.2f", item.subtotal) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="alert-info text-sm">Sin productos en este pedido.</div>
        <% end %>

        <!-- Info pago (pedido cerrado) -->
        <% if @current_order.status == 1 && @current_order.monto_pagado.present? %>
          <div class="bg-slate-50 rounded-xl p-4 grid grid-cols-3 gap-3">
            <div>
              <p class="text-xs text-slate-500 mb-0.5">Tipo de pago</p>
              <% if @current_order.tipo_pago == 'efectivo' %>
                <span class="badge-success">Efectivo</span>
              <% else %>
                <span class="badge-info">Transferencia</span>
              <% end %>
            </div>
            <div>
              <p class="text-xs text-slate-500 mb-0.5">Monto pagado</p>
              <p class="font-bold text-emerald-700">$<%= sprintf("%.2f", @current_order.monto_pagado) %></p>
            </div>
            <% if @current_order.tipo_pago == 'efectivo' && @current_order.vuelto.present? %>
              <div>
                <p class="text-xs text-slate-500 mb-0.5">Vuelto</p>
                <p class="font-bold text-blue-700">$<%= sprintf("%.2f", @current_order.vuelto) %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <!-- Total -->
        <div class="flex items-center justify-between bg-navy-900 text-white rounded-xl px-5 py-4">
          <span class="text-slate-400">Total del pedido</span>
          <span class="text-xl font-bold">$<%= sprintf("%.2f", @current_order.total) %></span>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>
<% end %>

<!-- Data para JavaScript -->
<script type="application/json" id="order-data">
<%= {
  orderId: @current_order&.id,
  orderStatus: @current_order&.status || 0,
  orderTotal: @current_order&.total || 0,
  cliente: @current_order&.cliente || '',
  mesero: @current_order&.mesero || '',
  tipoServicio: @current_order&.tipo_servicio || 'mesa',
  createdAt: @current_order&.created_at&.strftime("%d/%m/%y %H:%M") || ''
}.to_json.html_safe %>
</script>

<script type="module">
  import "home";
</script>
