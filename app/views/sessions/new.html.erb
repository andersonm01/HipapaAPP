<div class="w-full max-w-sm">
  <!-- Logo / Brand -->
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-14 h-14 bg-brand-500 rounded-2xl mb-4 shadow-lg">
      <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-white tracking-tight">HipapaAPP</h1>
    <p class="text-slate-400 text-sm mt-1">Sistema de Pedidos</p>
  </div>

  <!-- Card -->
  <div class="bg-white rounded-2xl shadow-modal p-8">
    <% if flash[:alert] %>
      <div class="alert-danger mb-5 rounded-lg">
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        <span><%= flash[:alert] %></span>
      </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="alert-success mb-5 rounded-lg">
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span><%= flash[:notice] %></span>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, class: "form-input", placeholder: "usuario@ejemplo.com", autofocus: true, required: true %>
        </div>

        <div>
          <%= f.label :password, "Contraseña", class: "form-label" %>
          <%= f.password_field :password, class: "form-input", placeholder: "••••••••", required: true %>
        </div>

        <%= f.submit "Iniciar Sesión", class: "btn-primary btn-lg w-full mt-2 cursor-pointer" %>
      </div>
    <% end %>

    <% if ENV['GOOGLE_CLIENT_ID'].present? %>
      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-slate-200"></div>
        </div>
        <div class="relative text-center">
          <span class="px-3 bg-white text-slate-400 text-xs">o continúa con</span>
        </div>
      </div>

      <%= button_to "/auth/google_oauth2", method: :post,
          class: "btn-secondary w-full gap-3",
          data: { turbo: false } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.35-8.16 2.35-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        Continuar con Google
      <% end %>
    <% end %>
  </div>

  <p class="text-center text-slate-500 text-xs mt-6">
    Solo usuarios autorizados · HipapaAPP &copy; <%= Date.today.year %>
  </p>
</div>
