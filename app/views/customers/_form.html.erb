<% if customer.errors.any? %>
  <div class="alert-danger mb-4">
    <ul class="list-disc ml-4 text-sm">
      <% customer.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="md:col-span-2">
    <label class="form-label">Nombre *</label>
    <%= f.text_field :nombre, class: "form-input", placeholder: "Nombre del cliente", required: true %>
  </div>
  <div>
    <label class="form-label">WhatsApp</label>
    <%= f.text_field :whatsapp, class: "form-input", placeholder: "573001234567" %>
    <p class="form-hint">Número completo con código de país</p>
  </div>
  <div>
    <label class="form-label">Precio domicilio personalizado</label>
    <div class="input-group">
      <span class="input-group-text">$</span>
      <%= f.text_field :precio_domicilio, class: "form-input", placeholder: "0" %>
    </div>
    <p class="form-hint">Dejar en 0 para precio estándar</p>
  </div>
  <div class="md:col-span-2">
    <label class="form-label">Dirección</label>
    <%= f.text_field :direccion, class: "form-input", placeholder: "Calle, barrio..." %>
  </div>
  <div class="md:col-span-2">
    <label class="form-label">Notas internas</label>
    <%= f.text_area :notas, class: "form-textarea", rows: 2, placeholder: "Alérgico a..., prefiere..." %>
  </div>
</div>

<div class="flex gap-3 mt-5">
  <%= f.submit customer.persisted? ? "Actualizar" : "Crear cliente", class: "btn-primary" %>
  <%= link_to "Cancelar", customers_path, class: "btn-secondary" %>
</div>
