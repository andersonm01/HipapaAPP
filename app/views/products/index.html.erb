<div class="page-header">
  <div>
    <h1 class="page-title">Productos</h1>
    <p class="text-sm text-slate-500 mt-0.5"><%= @products.count %> producto(s) registrado(s)</p>
  </div>
  <% if current_user&.admin? || current_user&.supervisor? %>
    <%= link_to new_product_path, class: "btn-primary" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      Nuevo Producto
    <% end %>
  <% end %>
</div>

<div class="card">
  <% if @products.present? %>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Foto</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Precio</th>
            <th>Categoría</th>
            <th>Estado</th>
            <% if current_user&.admin? || current_user&.supervisor? %>
              <th class="text-right">Acciones</th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <tr>
              <td>
                <% if product.foto.attached? %>
                  <%= image_tag product.foto, class: "w-10 h-10 rounded-lg object-cover" %>
                <% else %>
                  <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center text-lg">🍔</div>
                <% end %>
              </td>
              <td class="font-semibold text-slate-800">
                <%= product.nombre %>
                <% if product.costo_calculado %>
                  <span class="block text-xs font-normal text-gray-400">
                    Costo: $<%= number_with_precision(product.costo_calculado, precision:2) %>
                    <% if product.margen_ganancia %>
                      · Margen: <span class="<%= product.rentable? ? 'text-green-500' : 'text-red-500' %>"><%= product.margen_ganancia %>%</span>
                    <% end %>
                  </span>
                <% end %>
              </td>
              <td class="text-slate-500 max-w-xs">
                <%= truncate(product.descripcion, length: 60) if product.descripcion.present? %>
              </td>
              <td class="font-semibold text-slate-800">$<%= sprintf("%.2f", product.precio) %></td>
              <td>
                <span class="badge-gray"><%= product.categoria %></span>
              </td>
              <td>
                <% if product.activo %>
                  <span class="badge-success">Activo</span>
                <% else %>
                  <span class="badge-danger">Inactivo</span>
                <% end %>
              </td>
              <% if current_user&.admin? || current_user&.supervisor? %>
                <td class="text-right">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to product_recipe_path(product), class: "btn-secondary btn-sm" do %>
                      🧾 Receta
                    <% end %>
                    <%= link_to product_path(product), class: "btn-ghost btn-sm" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                      </svg>
                      Ver
                    <% end %>
                    <%= link_to edit_product_path(product), class: "btn-secondary btn-sm" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                      </svg>
                      Editar
                    <% end %>
                    <%= link_to product_path(product),
                        class: "btn-outline-danger btn-sm",
                        data: { turbo_method: :delete, turbo_confirm: "¿Eliminar '#{product.nombre}'?" } do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                      Eliminar
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">
      <svg class="w-12 h-12 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
      </svg>
      <p class="font-medium text-slate-500">No hay productos registrados</p>
      <% if current_user&.admin? || current_user&.supervisor? %>
        <%= link_to "Crear primer producto", new_product_path, class: "btn-primary btn-sm mt-3" %>
      <% end %>
    </div>
  <% end %>
</div>
