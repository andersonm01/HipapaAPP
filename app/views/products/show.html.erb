<div class="page-header">
  <h1 class="page-title">Detalle del Producto</h1>
  <%= link_to products_path, class: "btn-secondary btn-sm" do %>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    Volver
  <% end %>
</div>

<div class="max-w-2xl">
  <div class="card">
    <div class="card-header">
      <div>
        <h2 class="font-bold text-slate-800 text-lg"><%= @product.nombre %></h2>
        <span class="text-xs text-slate-400 font-mono">ID #<%= @product.id %></span>
      </div>
      <% if current_user&.admin? || current_user&.supervisor? %>
        <div class="flex gap-2">
          <%= link_to edit_product_path(@product), class: "btn-secondary btn-sm" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
            Editar
          <% end %>
          <%= link_to product_path(@product),
              class: "btn-outline-danger btn-sm",
              data: { turbo_method: :delete, turbo_confirm: "¿Eliminar '#{@product.nombre}'?" } do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Eliminar
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="card-body">
      <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
        <div class="col-span-2">
          <dt class="form-label">Descripción</dt>
          <dd class="text-slate-700 text-sm"><%= @product.descripcion.present? ? @product.descripcion : "—" %></dd>
        </div>
        <div>
          <dt class="form-label">Precio</dt>
          <dd class="text-2xl font-bold text-slate-800">$<%= sprintf("%.2f", @product.precio) %></dd>
        </div>
        <div>
          <dt class="form-label">Categoría</dt>
          <dd><span class="badge-gray"><%= @product.categoria %></span></dd>
        </div>
        <div>
          <dt class="form-label">Estado</dt>
          <dd>
            <% if @product.activo %>
              <span class="badge-success">Activo</span>
            <% else %>
              <span class="badge-danger">Inactivo</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="form-label">Creado</dt>
          <dd class="text-sm text-slate-600"><%= @product.created_at.strftime("%d/%m/%Y %H:%M") %></dd>
        </div>
        <div>
          <dt class="form-label">Actualizado</dt>
          <dd class="text-sm text-slate-600"><%= @product.updated_at.strftime("%d/%m/%Y %H:%M") %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
