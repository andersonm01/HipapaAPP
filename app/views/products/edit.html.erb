<div class="page-header">
  <h1 class="page-title">Editar Producto</h1>
  <%= link_to products_path, class: "btn-secondary btn-sm" do %>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    Volver
  <% end %>
</div>

<div class="max-w-2xl">
  <div class="card">
    <div class="card-header">
      <h2 class="font-semibold text-slate-800">Información del Producto</h2>
      <span class="text-xs text-slate-400 font-mono">ID #<%= @product.id %></span>
    </div>
    <div class="card-body">
      <%= form_with model: @product, local: true, data: { turbo: false } do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :nombre, "Nombre", class: "form-label" %>
            <%= f.text_field :nombre, class: "form-input #{'border-red-400' if @product.errors[:nombre].any?}", placeholder: "Nombre del producto", required: true %>
            <% if @product.errors[:nombre].any? %>
              <p class="form-error"><%= @product.errors[:nombre].first %></p>
            <% end %>
          </div>

          <div>
            <%= f.label :descripcion, "Descripción", class: "form-label" %>
            <%= f.text_area :descripcion, class: "form-textarea", rows: 3, placeholder: "Descripción opcional..." %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :precio, "Precio", class: "form-label" %>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <%= f.number_field :precio, class: "form-input", placeholder: "0.00", step: "0.01", min: "0", required: true %>
              </div>
              <% if @product.errors[:precio].any? %>
                <p class="form-error"><%= @product.errors[:precio].first %></p>
              <% end %>
            </div>

            <div>
              <%= f.label :categoria, "Categoría", class: "form-label" %>
              <%= f.text_field :categoria, class: "form-input #{'border-red-400' if @product.errors[:categoria].any?}", placeholder: "Ej: Bebidas", required: true %>
              <% if @product.errors[:categoria].any? %>
                <p class="form-error"><%= @product.errors[:categoria].first %></p>
              <% end %>
            </div>
          </div>

          <!-- Foto -->
          <div>
            <label class="form-label">Foto del producto</label>
            <% if @product.foto.attached? %>
              <div class="mb-2 flex items-center gap-3">
                <%= image_tag @product.foto, class: "h-20 w-20 rounded-lg object-cover border" %>
                <span class="text-sm text-gray-500">Foto actual</span>
              </div>
            <% end %>
            <%= f.file_field :foto, class: "form-input", accept: "image/*" %>
          </div>

          <!-- Posición -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="form-label">Posición visual</label>
              <%= f.number_field :posicion, class: "form-input", min: 0 %>
            </div>
            <% if @product.costo_calculado %>
              <div>
                <label class="form-label">Costo calculado (receta)</label>
                <div class="form-input bg-gray-50 text-gray-600">
                  $<%= number_with_precision(@product.costo_calculado, precision: 2) %>
                  <% if @product.margen_ganancia %>
                    · Margen: <%= @product.margen_ganancia %>%
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

          <label class="flex items-center gap-3 cursor-pointer">
            <%= f.check_box :activo, class: "w-4 h-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" %>
            <div>
              <span class="text-sm font-semibold text-slate-700">Producto activo</span>
              <p class="text-xs text-slate-500">Los productos inactivos no aparecen en pedidos</p>
            </div>
          </label>
        </div>

        <div class="flex items-center justify-end gap-3 mt-6 pt-5 border-t border-slate-200">
          <%= link_to "Cancelar", products_path, class: "btn-secondary" %>
          <%= f.submit "Guardar Cambios", class: "btn-primary cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
