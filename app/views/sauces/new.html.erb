<div class="page-header">
  <h1 class="page-title">Nueva Salsa</h1>
  <%= link_to "← Volver", sauces_path, class: "btn-secondary btn-sm" %>
</div>
<div class="card max-w-md">
  <div class="card-body">
    <%= form_with model: @sauce, local: true, data: { turbo: false } do |f| %>
      <%= render 'form', sauce: @sauce, f: f %>
    <% end %>
  </div>
</div>
