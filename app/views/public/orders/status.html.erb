<div class="text-center py-8">
  <% case @order.kitchen_status
  when 'pending' %>
    <div class="text-5xl mb-4">⏳</div>
    <h2 class="text-xl font-bold text-gray-800 mb-2">Recibimos tu pedido</h2>
    <p class="text-gray-500">Tu pedido está en espera de ser preparado</p>
  <% when 'preparing' %>
    <div class="text-5xl mb-4 animate-bounce">👨‍🍳</div>
    <h2 class="text-xl font-bold text-orange-500 mb-2">¡En preparación!</h2>
    <p class="text-gray-500">Nuestro equipo está preparando tu pedido</p>
  <% when 'ready' %>
    <div class="text-5xl mb-4">🎉</div>
    <h2 class="text-xl font-bold text-green-600 mb-2">¡Listo para entregar!</h2>
    <p class="text-gray-500">Tu pedido está listo, pasa a recogerlo</p>
  <% when 'delivered' %>
    <div class="text-5xl mb-4">✅</div>
    <h2 class="text-xl font-bold text-gray-700 mb-2">¡Entregado!</h2>
    <p class="text-gray-500">Gracias por tu pedido. ¡Que lo disfrutes!</p>
  <% end %>

  <div class="mt-6 bg-white rounded-2xl shadow-sm border p-4 text-left">
    <div class="flex justify-between items-center mb-3">
      <span class="font-semibold text-gray-700">Tu pedido <%= @order.numero_orden || "##{@order.id}" %></span>
      <span class="text-xs text-gray-400"><%= @order.created_at.strftime('%d/%m/%Y %H:%M') %></span>
    </div>
    <% @order.order_items.each do |item| %>
      <div class="flex justify-between text-sm py-1 border-b last:border-b-0">
        <span><%= item.cantidad %>x <%= item.product.nombre %></span>
        <span class="font-semibold">$<%= number_with_precision(item.subtotal, precision: 0) %></span>
      </div>
    <% end %>
    <div class="flex justify-between font-bold mt-2 text-base">
      <span>Total</span>
      <span>$<%= number_with_precision(@order.total, precision: 0, delimiter: ',') %></span>
    </div>
  </div>

  <div class="mt-4 space-y-2">
    <%= link_to "Ver menú", public_menu_path, class: "block w-full py-3 rounded-xl font-semibold text-black text-center", style: "background: var(--pub-brand, #f59e0b);" %>
    <% if @business.whatsapp_negocio.present? %>
      <a href="https://wa.me/<%= @business.whatsapp_negocio.gsub(/\D/,'') %>"
         target="_blank"
         class="block w-full py-3 rounded-xl font-semibold text-white text-center bg-green-500">
        Contactar por WhatsApp
      </a>
    <% end %>
  </div>
</div>

<!-- Auto-refresh si el pedido no está entregado -->
<% unless @order.kitchen_status == 'delivered' %>
  <meta http-equiv="refresh" content="15">
<% end %>
