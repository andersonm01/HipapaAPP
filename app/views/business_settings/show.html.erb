<div class="page-header">
  <h1 class="page-title">Configuración del Negocio</h1>
</div>

<div class="card max-w-2xl">
  <div class="card-body">
    <%= form_with model: @setting, url: business_settings_path, method: :patch, local: true, data: { turbo: false } do |f| %>
      <% if @setting.errors.any? %>
        <div class="alert-danger mb-4">
          <ul class="list-disc ml-4 text-sm">
            <% @setting.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="md:col-span-2">
          <label class="form-label">Nombre del negocio</label>
          <%= f.text_field :nombre, class: "form-input", placeholder: "Hi Papa" %>
        </div>

        <div>
          <label class="form-label">Teléfono</label>
          <%= f.text_field :telefono, class: "form-input", placeholder: "3001234567" %>
        </div>

        <div>
          <label class="form-label">WhatsApp del negocio</label>
          <%= f.text_field :whatsapp_negocio, class: "form-input", placeholder: "573001234567" %>
          <p class="form-hint">Número completo con código de país para recibir pedidos online</p>
        </div>

        <div class="md:col-span-2">
          <label class="form-label">Dirección</label>
          <%= f.text_field :direccion, class: "form-input", placeholder: "Calle 123 #45-67" %>
        </div>

        <div class="md:col-span-2">
          <label class="form-label">Descripción</label>
          <%= f.text_area :descripcion, class: "form-textarea", rows: 3, placeholder: "Las mejores hamburguesas y papas..." %>
        </div>

        <!-- Colores -->
        <div>
          <label class="form-label">Color Primario (botones, acentos)</label>
          <div class="flex gap-2 items-center">
            <%= f.color_field :color_primario, class: "h-10 w-16 rounded border cursor-pointer" %>
            <%= f.text_field :color_primario, class: "form-input", placeholder: "#f59e0b", id: "cp_text" %>
          </div>
        </div>

        <div>
          <label class="form-label">Color Secundario (navbar)</label>
          <div class="flex gap-2 items-center">
            <%= f.color_field :color_secundario, class: "h-10 w-16 rounded border cursor-pointer" %>
            <%= f.text_field :color_secundario, class: "form-input", placeholder: "#0f172a" %>
          </div>
        </div>

        <div>
          <label class="form-label">Color Acento</label>
          <div class="flex gap-2 items-center">
            <%= f.color_field :color_acento, class: "h-10 w-16 rounded border cursor-pointer" %>
            <%= f.text_field :color_acento, class: "form-input", placeholder: "#fbbf24" %>
          </div>
        </div>

        <!-- Logo -->
        <div>
          <label class="form-label">Logo del negocio</label>
          <% if @setting.logo.attached? %>
            <div class="mb-2 flex items-center gap-3">
              <%= image_tag @setting.logo, class: "h-16 w-16 rounded-lg object-cover border" %>
              <span class="text-sm text-gray-500">Logo actual</span>
            </div>
          <% end %>
          <%= f.file_field :logo, class: "form-input", accept: "image/*" %>
          <p class="form-hint">PNG o JPG recomendado. Máx 2MB.</p>
        </div>
      </div>

      <div class="flex gap-3 mt-6">
        <%= f.submit "Guardar cambios", class: "btn-primary" %>
        <%= link_to "Vista pública del menú", public_menu_path, class: "btn-secondary", target: "_blank" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  // Sincronizar color picker ↔ text field para cada par de colores
  document.querySelectorAll('input[type="color"]').forEach(function(picker) {
    const name = picker.name;
    // Buscar el text field con el mismo name que NO sea el picker
    const siblings = document.querySelectorAll('input[type="text"][name="' + name + '"]');
    siblings.forEach(function(text) {
      // picker → text
      picker.addEventListener('input', function() { text.value = picker.value; });
      // text → picker
      text.addEventListener('input', function() {
        if (/^#[0-9a-fA-F]{6}$/.test(text.value)) picker.value = text.value;
      });
    });
  });
</script>
