<div class="page-header">
  <div>
    <h1 class="page-title">Gestión de Usuarios</h1>
    <p class="text-sm text-slate-500 mt-0.5"><%= @users.count %> usuario(s) registrado(s)</p>
  </div>
  <%= link_to new_admin_user_path, class: "btn-primary" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
    </svg>
    Nuevo Usuario
  <% end %>
</div>

<div class="card">
  <% if @users.present? %>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Usuario</th>
            <th>Rol</th>
            <th>Estado</th>
            <th>Proveedor</th>
            <th>Creado</th>
            <th class="text-right">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr class="<%= user == current_user ? 'bg-amber-50/50' : '' %>">
              <td>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-slate-600 font-bold text-sm shrink-0">
                    <%= user.name.first.upcase %>
                  </div>
                  <div>
                    <div class="font-semibold text-slate-800">
                      <%= user.name %>
                      <% if user == current_user %>
                        <span class="badge-warning ml-1">tú</span>
                      <% end %>
                    </div>
                    <div class="text-xs text-slate-500"><%= user.email %></div>
                  </div>
                </div>
              </td>
              <td>
                <span class="nav-role-badge role-<%= user.role %>"><%= user.role %></span>
              </td>
              <td>
                <% if user.active? %>
                  <span class="badge-success">Activo</span>
                <% else %>
                  <span class="badge-gray">Inactivo</span>
                <% end %>
              </td>
              <td>
                <% if user.provider.present? %>
                  <span class="badge-info"><%= user.provider %></span>
                <% else %>
                  <span class="text-slate-400 text-xs">—</span>
                <% end %>
              </td>
              <td class="text-slate-500 text-xs"><%= user.created_at.strftime("%d/%m/%Y") %></td>
              <td class="text-right">
                <div class="flex items-center justify-end gap-1">
                  <%= link_to edit_admin_user_path(user), class: "btn-secondary btn-sm" do %>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Editar
                  <% end %>

                  <%= button_to toggle_active_admin_user_path(user), method: :patch,
                      class: "btn-sm #{user.active? ? 'btn-secondary' : 'btn-success'}",
                      data: { turbo: false } do %>
                    <%= user.active? ? "Desactivar" : "Activar" %>
                  <% end %>

                  <% unless user == current_user %>
                    <%= button_to admin_user_path(user), method: :delete,
                        class: "btn-outline-danger btn-sm",
                        data: { turbo: false, turbo_confirm: "¿Eliminar a #{user.name}?" } do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="empty-state">
      <svg class="w-12 h-12 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      <p class="font-medium">No hay usuarios registrados</p>
    </div>
  <% end %>
</div>
